import os
from langchain_text_splitters import RecursiveCharacterTextSplitter
from langchain_ollama import OllamaEmbeddings
from langchain_chroma import Chroma

def construir_base_vectorial(ruta_texto, directorio_db):
    print("-> Paso 1: Cargando el documento de texto...")
    if not os.path.exists(ruta_texto):
        print(f"Error: No se encontró el archivo {ruta_texto}")
        return
        
    with open(ruta_texto, 'r', encoding='utf-8') as f:
        texto_completo = f.read()
    
    print("-> Paso 2: Dividiendo el texto en fragmentos (Chunks)...")
    text_splitter = RecursiveCharacterTextSplitter(
        chunk_size=1000,
        chunk_overlap=200,
        length_function=len
    )
    fragmentos = text_splitter.create_documents([texto_completo])
    print(f"   Se crearon {len(fragmentos)} fragmentos listos para procesar.")

    print("-> Paso 3: Conectando con Ollama para los Embeddings...")
    modelo_embeddings = OllamaEmbeddings(
        model="nomic-embed-text"
    )

    print("-> Paso 4: Generando vectores y guardando en ChromaDB local...")
    Chroma.from_documents(
        documents=fragmentos,
        embedding=modelo_embeddings,
        persist_directory=directorio_db
    )
    
    print(f"-> ¡Proceso finalizado! Base de datos guardada en la carpeta: '{directorio_db}'")

if __name__ == "__main__":
    ruta_archivo_entrada = os.path.join("data", "bbva_tarjetas.txt")
    carpeta_base_datos = "chroma_db"
    
    construir_base_vectorial(ruta_archivo_entrada, carpeta_base_datos)
